<Window x:Class="AresAssistant.Views.AresMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="18"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Message -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header: icon + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Path x:Name="IconPath"
                      Data="M 8,0 L 16,11 L 8,22 L 0,11 Z"
                      Fill="{DynamicResource AccentBrush}" Width="14" Height="20"
                      Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" Text="ARES"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message body -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16,14">
                <TextBlock x:Name="MessageText"
                           Foreground="{DynamicResource TextBrush}" FontSize="13"
                           FontFamily="Consolas" LineHeight="20"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <StackPanel x:Name="ButtonPanel" Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,18,0,0">
                <!-- Buttons are added programmatically -->
            </StackPanel>
        </Grid>
    </Border>
</Window>
