<UserControl x:Class="AresAssistant.Views.FullHudModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1200" Height="800">

    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Header spans all columns -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#141414" Offset="0"/>
                        <GradientStop Color="#080808" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 10,0 L 20,14 L 10,28 L 0,14 Z"
                              Fill="{DynamicResource AccentBrush}" Width="20" Height="28"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}" FontFamily="Consolas" FontSize="18"
                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — HUD COMPLETO"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#999999" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="⊟" ToolTip="Modo overlay"
                                Click="ToggleMode_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="⚙" ToolTip="Ajustes"
                                Click="Settings_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="🗑" ToolTip="Limpiar chat"
                                Click="ClearChat_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="✕" ToolTip="Cerrar"
                                Click="Close_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Left panel: Tool list -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="0,0,1,0"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HERRAMIENTAS" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ToolNames.Count, StringFormat='{}{0} disponibles'}"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="#808080" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="5,3" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1f1f1f"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#777777"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Foreground" Value="#aaaaaa"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Center: Chat messages -->
            <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6,0,0" Loaded="MessageBubble_Loaded"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <Border MaxWidth="640" MinWidth="180" Padding="14,10">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem Header="Copiar" Tag="📋" Style="{StaticResource DarkMenuItem}" Click="CopyMessage_Click"/>
                                            <MenuItem Header="Leer en voz alta" Tag="🔊" Style="{StaticResource DarkMenuItem}" Click="SpeakMessage_Click"/>
                                            <MenuItem Header="Eliminar mensaje" Tag="🗑" Style="{StaticResource DarkMenuItem}" Click="DeleteMessage_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1c1c1c"/>
                                            <Setter Property="CornerRadius" Value="14,14,14,4"/>
                                            <Setter Property="BorderBrush" Value="#282828"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background" Value="#241010"/>
                                                    <Setter Property="CornerRadius" Value="14,14,4,14"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <!-- Header: icon + role + timestamp -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- ARES diamond icon -->
                                                <Path Data="M 4,0 L 8,6 L 4,12 L 0,6 Z"
                                                      Width="8" Height="12"
                                                      VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <!-- User dot -->
                                                <Ellipse Width="10" Height="10"
                                                         VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <!-- Role name -->
                                                <TextBlock FontSize="11" FontFamily="Consolas"
                                                           FontWeight="SemiBold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ARES"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Text" Value="TÚ"/>
                                                                    <Setter Property="Foreground" Value="#888888"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       FontSize="9" FontFamily="Consolas" Foreground="#454545"/>
                                        </Grid>
                                        <!-- Separator -->
                                        <Rectangle Height="1" Margin="-2,0,-2,8" Opacity="0.3">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Fill" Value="#333333"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentGlowBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>
                                        <!-- Content -->
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   FontSize="{DynamicResource FontSizeNormal}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   LineHeight="22" MaxWidth="610"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Right panel: System status -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="1,0,0,0"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ESTADO" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Rectangle DockPanel.Dock="Top" Height="1" Fill="#222222" Margin="0,0,0,10"/>
                    <TextBlock x:Name="SystemStatus"
                               Text="{Binding StatusText, FallbackValue='Esperando...'}"
                               FontSize="11" DockPanel.Dock="Top"
                               FontFamily="Consolas" Foreground="#aaaaaa"
                               TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- Status bar / Thinking indicator -->
            <Grid Grid.Row="2" Grid.Column="1" Height="22" Margin="16,0">
                <!-- Status text when idle -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="11" FontStyle="Italic" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Spinning arc when thinking -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Canvas Width="18" Height="18" VerticalAlignment="Center">
                        <Canvas.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="HudSpinArc"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Canvas.Triggers>
                        <Ellipse Width="18" Height="18"
                                 Stroke="#2a2a2a" StrokeThickness="2.5" Fill="Transparent"/>
                        <Path x:Name="HudSpinArc"
                              Data="M 9,1.5 A 7.5,7.5 0 1 1 1.5,9"
                              Stroke="{DynamicResource AccentBrush}"
                              StrokeThickness="2.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.RenderTransform>
                                <RotateTransform CenterX="9" CenterY="9"/>
                            </Path.RenderTransform>
                            <Path.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.7" Color="#ff2222"/>
                            </Path.Effect>
                        </Path>
                    </Canvas>
                    <TextBlock Text="Pensando" Margin="8,0,0,0"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontFamily="Consolas"
                               FontSize="11" VerticalAlignment="Center" FontStyle="Italic"/>
                    <!-- Animated dots -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="1,2,0,0">
                        <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Margin="0,0,2.5,0" Opacity="0.15">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0"/>
                                </Storyboard></BeginStoryboard></EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Margin="0,0,2.5,0" Opacity="0.15">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.15"/>
                                </Storyboard></BeginStoryboard></EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Opacity="0.15">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.3"/>
                                </Storyboard></BeginStoryboard></EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Input row -->
            <Border Grid.Row="3" Grid.Column="1"
                    Background="#0a0a0a" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="InputBox"
                                 Style="{StaticResource AresTextBox}"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="Input_KeyDown"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="38" MaxHeight="120"
                                 VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto"
                                 MaxLength="4000"/>
                        <TextBlock Text="Escribe un mensaje..."
                                   IsHitTestVisible="False"
                                   Margin="10,8,0,0"
                                   VerticalAlignment="Top"
                                   Foreground="#505050"
                                   FontStyle="Italic"
                                   FontSize="{DynamicResource FontSizeNormal}"
                                   Visibility="{Binding InputText, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </Grid>

                    <Button Grid.Column="1" Content="Exportar"
                            Style="{StaticResource GhostButton}"
                            Margin="8,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Export_Click"/>

                    <Button Grid.Column="2" Content="Enviar →"
                            Style="{StaticResource AresButton}"
                            Margin="6,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Send_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.5" Color="#ff2222"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
